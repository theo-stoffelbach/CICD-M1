# Génère avec : openssl rand -hex 32
SECRET_KEY=

# URL de l'API (utilisé au build du frontend via VITE_API_URL)
# En prod NAS : https://wordle-api.theo-stoffelbach.fr
VITE_API_URL=https://wordle-api.theo-stoffelbach.fr

# Origines autorisées par le backend CORS (séparées par des virgules)
# En prod NAS : https://wordle.theo-stoffelbach.fr
CORS_ORIGINS=https://wordle.theo-stoffelbach.fr

# PostgreSQL
POSTGRES_DB=wordle
POSTGRES_USER=wordle
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://wordle:<password>@wordle-db:5432/wordle
